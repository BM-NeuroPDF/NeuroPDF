# NeuroPDF backend (FastAPI) — örnek ortam değişkenleri. Kopyalayıp backend/.env oluşturun.

# --- Ortam ---
ENVIRONMENT=development
# Swagger vb. geliştirici çıktıları (main.py)
DEBUG=false

# --- API ---
API_NAME=PDF Project API
# CORS ve yönlendirmeler için frontend kök URL
FRONTEND_ORIGIN=http://localhost:3000

# --- JWT (backend oturum / API token) ---
JWT_SECRET=ornek_guclu_jwt_secret_degistirin
JWT_EXPIRES_MIN=60

# --- Google (id_token doğrulama; yalnızca client id) ---
GOOGLE_CLIENT_ID=google_oauth_client_id_ornek

# --- Supabase ---
USE_SUPABASE=false
SUPABASE_URL=https://ornek.supabase.co
SUPABASE_KEY=supabase_anon_or_service_role_ornek
SUPABASE_DATABASE_URL=postgresql://user:pass@host:5432/db
# USE_SUPABASE=false iken yerel Postgres bağlantısı
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neuropdf
# Avatar dosyaları yerel disk (boşsa varsayılan static yol)
LOCAL_AVATAR_STORAGE_ROOT=

# --- PostgreSQL (parçalı veya tek DATABASE_URL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neuropdf
DB_USER=postgres
DB_PASSWORD=ornek_parola
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_SSLMODE=disable

# --- PostgreSQL resmi Docker imajı (docker-compose.prod.yml db servisi; env_file ile okunur) ---
# Bu üçlü, DATABASE_URL / LOCAL_DATABASE_URL içindeki kullanıcı-parola-veritabanı ile aynı olmalıdır.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=neuropdf

# --- Redis ---
REDIS_URL=
REDIS_HOST=redis_cache
REDIS_PORT=6379

# --- AI servisi ve anahtarlar ---
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=ornek_ai_service_x_api_key
# Async özet callback (/files/callback); aiService Celery ile aynı değer (boş bırakılırsa callback 403)
INTERNAL_CALLBACK_SECRET=change-me-to-a-random-256-bit-secret
GEMINI_API_KEY=
XAI_API_KEY=
HUGGINGFACE_API_KEY=

# --- Misafir / dosya limitleri ---
MAX_GUEST_USAGE=3
MAX_FILE_SIZE_GUEST_MB=5
MAX_FILE_SIZE_USER_MB=7

# --- SMTP ve 2FA (Pydantic varsayılanları; production için doldurun) ---
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
OTP_EMAIL_TTL_SECONDS=180
VERIFY_2FA_MAX_FAILS=3
VERIFY_2FA_LOCKOUT_SECONDS=180

# --- E2E sabit OTP (yalnızca yerel/CI; production’da kapalı tutun) ---
E2E_MAGIC_OTP_ENABLED=false
E2E_MAGIC_OTP_EMAIL=e2e@ornek.com
E2E_MAGIC_OTP_ALL_USERS=false

# --- Pytest: test veritabanı (conftest; isteğe bağlı override) ---
TEST_DB_USER=
TEST_DB_PASSWORD=
TEST_DB_HOST=
TEST_DB_PORT=
TEST_DB_NAME=neuropdf_test
TEST_DB_SSLMODE=
