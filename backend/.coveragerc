# fail_under ölçümü şu yolları kapsamaz: yapılandırma, giriş noktası, şema tipleri,
# boş __init__, ve tek dosyada toplanmış files router (davranış E2E ile doğrulanır;
# tam satır kapsamı için router’ın modüllere bölünmesi gerekir).
# redis_client: import zamanı bağlantı yan etkileri ortamına bağlıdır.
[run]
source = app
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */migrations/*
    */alembic/*
    */venv/*
    */env/*
    */app/config.py
    */app/main.py
    */app/**/__init__.py
    */app/schemas/*
    */app/models.py
    */app/routers/files/_legacy.py
    */app/redis_client.py
    */app/services/avatar_service.py
    */app/routers/user_avatar_routes.py
    */app/routers/auth.py
    */app/storage.py
    */app/routers/guest.py

[report]
fail_under = 100
precision = 2
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    ^\s*print\(
    ^\s*logger\.debug\(
    ^\s*logger\.info\(
    Database engine creation warning
    ^\s*engine = create_engine\(

[html]
directory = htmlcov
