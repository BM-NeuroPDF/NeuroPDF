{
  "name": "neuropdf-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --experimental-https -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:eslint": "eslint .",
    "format": "prettier --write 'src/**/*.{ts,tsx,md,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,md,json}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project='Desktop HD (720p)' --project='Desktop FHD (1080p)'",
    "test:e2e:responsive": "playwright test --project='Mobile (375p)' --project='Tablet (600p)' --project='Laptop (1366p)' --project='Desktop FHD (1080p)'",
    "analyze:dead": "ts-prune"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.51.0",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "next-auth": "^4.24.10",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.1.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.16",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "4.0.0-alpha.31",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.5.16",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "jsdom": "^25.0.1",
    "msw": "^2.12.14",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "tailwindcss": "4.0.0-alpha.31",
    "ts-prune": "^0.10.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
