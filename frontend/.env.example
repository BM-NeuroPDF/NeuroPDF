# NeuroPDF frontend — örnek ortam değişkenleri. Gerçek sırları buraya yazmayın; kopyalayıp .env.local oluşturun.

# --- Backend ve istemci API tabanı ---
# Sunucu tarafı proxy ve next.config rewrites için FastAPI kök URL (sonda / olmadan)
BACKEND_API_URL=http://localhost:8000

# Tarayıcıda kullanılan API tabanı (fetch / public istekler)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Google OAuth (NextAuth) ---
GOOGLE_CLIENT_ID=google_oauth_client_id_ornek
GOOGLE_CLIENT_SECRET=google_oauth_client_secret_ornek

# --- NextAuth oturum imzası ---
# Resmi NextAuth adı NEXTAUTH_SECRET (src/lib/auth.ts). Üretimde: openssl rand -base64 32
# src/auth.config.ts (Edge middleware) secret için AUTH_SECRET okur — değeri NEXTAUTH_SECRET ile aynı tutun.
NEXTAUTH_SECRET=ornek_openssl_rand_base64_32
AUTH_SECRET=

# --- Sentry (sunucu: sentry.server.config.ts; istemci: sentry.client / edge) ---
# Sunucu DSN boşsa NEXT_PUBLIC_SENTRY_DSN yedeklenir.
SENTRY_DSN=
# Sunucu: boşsa NODE_ENV. İstemci: NEXT_PUBLIC_SENTRY_ENV.
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_RELEASE=dev
# Boş bırakılırsa production'da 0.1, diğer ortamlarda 0.0 varsayılır.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
# Sürüm: CI/docker GIT_SHA; Vercel otomatik VERCEL_GIT_COMMIT_SHA.
GIT_SHA=dev
VERCEL_GIT_COMMIT_SHA=
# CI sourcemap upload (Next.js Sentry plugin; next.config.ts)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# next build ile bundle analizi (@next/bundle-analyzer)
ANALYZE=false

# --- Yükleme boyutu (MB) — istemci ve Next.js body limiti ---
# Tarayıcıda gösterilen limitler (tercih edilen)
NEXT_PUBLIC_MAX_FILE_SIZE_GUEST_MB=5
NEXT_PUBLIC_MAX_FILE_SIZE_USER_MB=50
# Legacy / sunucu tarafı eşleşmesi için (boşsa yukarıdakiler kullanılır)
MAX_FILE_SIZE_GUEST_MB=5
MAX_FILE_SIZE_USER_MB=50
# next.config serverActions bodySizeLimit için ek legacy anahtar
FRONTEND_MAX_UPLOAD_MB=50

# --- Playwright E2E (isteğe bağlı) ---
# CI=true Playwright davranışını sıkılaştırır
CI=
E2E_TEST_EMAIL=e2e_test_kullanici@ornek.com
E2E_TEST_PASSWORD=ornek_sifre
# Boşsa e-postadan türetilir (e2e/fixtures/test-data.ts historyFlowUser).
E2E_TEST_USERNAME=
E2E_PRO_EMAIL=pro@ornek.com
E2E_PRO_PASSWORD=ornek_sifre
E2E_PRO_USERNAME=pro_kullanici_ornek
E2E_STD_EMAIL=std@ornek.com
E2E_STD_PASSWORD=ornek_sifre
E2E_STD_USERNAME=std_kullanici_ornek
E2E_GUEST_MAX_USAGE=3
# 2FA/E2E: genel veya e-postaya özel (helpers: E2E_OTP_CODE_{EMAIL_NORMALIZE})
E2E_OTP_CODE=123456
E2E_SEED_USER=true
