# NeuroPDF aiService — örnek ortam değişkenleri. Gerçek anahtarları buraya yazmayın; kopyalayıp aiService/.env oluşturun.

# --- Ortam ---
# development: AI_SERVICE_API_KEY boşken X-API-Key doğrulaması atlanabilir (deps.py).
# production: GEMINI_API_KEY ve/veya LOCAL_LLM_URL zorunludur (config.py doğrulaması).
ENVIRONMENT=development
DEBUG=false
GIT_SHA=dev
SENTRY_DSN=
SENTRY_ENV=development
# Boş bırakılırsa production'da 0.1, diğer ortamlarda 0.0 varsayılır.
SENTRY_TRACES_SAMPLE_RATE=
METRICS_TOKEN=
METRICS_ALLOW_INSECURE_LOCAL=true

# --- Backend → AI Service (X-API-Key) ---
# Backend ile aynı değeri kullanın. Üretimde mutlaka güçlü bir anahtar tanımlayın.
AI_SERVICE_API_KEY=ornek_ai_service_x_api_key

# --- AI Service → Backend callback imzası ---
# backend/.env içindeki CALLBACK_SECRET ile birebir aynı olmalı.
CALLBACK_SECRET=change-me-to-a-random-256-bit-secret
# Legacy yedek isim (config.py): boşsa CALLBACK_SECRET kullanılır.
INTERNAL_CALLBACK_SECRET=

# --- Redis (Celery broker ve sonuç backend) ---
# Docker içi örnek: redis://redis_cache:6379
REDIS_URL=redis://localhost:6379

# --- Bulut LLM (Google Gemini) ---
# Yerel OpenAI uyumlu uç (LOCAL_LLM_URL) kullanıyorsanız boş bırakılabilir.
GEMINI_API_KEY=

# --- Yerel / OpenAI uyumlu uç (Ollama vb.) ---
# Örnek: http://localhost:11434/v1 veya http://ollama:11434/v1
LOCAL_LLM_URL=

# --- Ollama doğrudan istemci (LOCAL_LLM_URL boşken ollama.Client yolu) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# --- OpenAI uyumlu HTTP çağrıları (Bearer) ---
# Boşsa kod GEMINI_API_KEY veya yer tutucu anahtar kullanabilir (local_llm_service).
OPENAI_API_KEY=

# --- TTS (ElevenLabs; isteğe bağlı) ---
# Hem pydantic ayarları hem tts_manager os.getenv ile okur.
ELEVENLABS_API_KEY=
